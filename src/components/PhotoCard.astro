---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  author: string;
  authorName: string;
  image: ImageMetadata;
  category?: string;
}

const { title, author, authorName, image, category } = Astro.props;
---

<div
  class="photo-card group relative overflow-hidden cursor-zoom-in"
  data-author={author}
  data-author-name={authorName}
  data-title={title}
  data-category={category ?? ''}
  data-src={image.src}
>
  <Image
    src={image}
    alt={title}
    loading="lazy"
    decoding="async"
    format="webp"
    quality={82}
    class="w-full h-auto block transition-transform duration-700 ease-in-out group-hover:scale-105"
  />

  <!-- Hover overlay -->
  <div class="absolute inset-0 bg-film-950/0 group-hover:bg-film-950/45 transition-all duration-500 flex items-end pointer-events-none">
    <div class="w-full p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-500">
      <p class=" text-film-50 text-base italic leading-tight">{title}</p>
      <div class="flex items-center justify-between mt-1">
        <span class="font-body text-film-200 text-xs">{authorName}</span>
        {category && (
          <span class=" text-film-300 text-xs uppercase tracking-widest">{category}</span>
        )}
      </div>
    </div>
  </div>
</div>
