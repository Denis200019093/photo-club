---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import MemberCard from "../components/MemberCard.astro";

const members = await getCollection("members");
const photos = await getCollection("photos");

const photoCounts = Object.fromEntries(
  members.map((m) => [
    m.slug,
    photos.filter((p) => p.data.author === m.slug).length,
  ]),
);

const sorted = members.sort(
  (a, b) =>
    new Date(a.data.joined).getTime() - new Date(b.data.joined).getTime(),
);
---

<Layout title="Про нас" description="Учасники вінницького фотоклубу">
  <section class="max-w-7xl mx-auto px-6 pt-16 pb-12">
    <p class=" text-xs text-film-400 uppercase tracking-[0.2em] mb-3">
      Наш клуб
    </p>
    <h1 class=" text-3xl sm:text-5xl font-semibold text-film-950">
      Про клуб
    </h1>

    <p class="font-body text-film-500 text-sm leading-relaxed mt-6">
      Фотоклуб «Обрій» утворився в 1974 році завдяки групі фотоаматорів, що
      мешкали у м. Вінниці та мріяли створити у своєму місті осередок любителів
      художньої фотографії. Ще до створення клубу фотолюбителі починали
      знайомитись між собою, та збирались для спілкування у центральному парку
      міста Вінниці. Створення фотоклубу, який тоді належав Профспілковій
      організації міста, дало можливість фотографам регулярно збиратись у
      спеціально відведеному для цього приміщенні та вести активну діяльність у
      своєму місті. Це організація фотовиставок, обмін фотографіями для виставок
      з іншими фотоклубами Радянського Союзу, проведення пленерів, семінарів,
      дискусій; здобування різноманітного фотографічного обладнання для потреб
      клубу. Був створений фотогурток для школярів.
    </p>
  </section>

  <section class="max-w-7xl mx-auto px-6 pt-16 pb-12">
    <p class=" text-xs text-film-400 uppercase tracking-[0.2em] mb-3">
      Наша команда
    </p>
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
      <h1 class=" text-5xl sm:text-6xl font-semibold text-film-950">
        Про нас
      </h1>
      <p class="font-body text-film-500 max-w-sm text-sm leading-relaxed">
        Ми — спільнота фотографів з Вінниці, які збираються щомісяця, щоб
        ділитися роботами, ідеями і любов'ю до світла.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-6">
    <div class="border-t border-film-200"></div>
  </div>

  <section class="max-w-7xl mx-auto px-6 py-12">
    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-14"
    >
      {
        sorted.map((member) => (
          <MemberCard
            name={member.data.name}
            slug={member.slug}
            role={member.data.role}
            bio={member.data.bio}
            avatar={member.data.avatar}
            instagram={member.data.instagram}
            joined={member.data.joined}
            photoCount={photoCounts[member.slug] ?? 0}
          />
        ))
      }
    </div>
  </section>

  <section class="bg-film-950 text-film-50 mt-16">
    <div
      class="max-w-7xl mx-auto px-6 py-20 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center"
    >
      <div>
        <p
          class=" text-xs text-film-400 uppercase tracking-[0.2em] mb-4"
        >
          Наша філософія
        </p>
        <h2
          class=" text-4xl font-semibold italic leading-tight mb-6"
        >
          "Найкращий фотоапарат —<br />той, що в руках"
        </h2>
        <p class="font-body text-film-300 leading-relaxed text-sm">
          Клуб засновано у 2019 році. Ми не змагаємось — ми надихаємо одне
          одного. Щомісячні зустрічі, спільні виходи на зйомку, виставки і
          безмежна любов до фотографії.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-4">
        {
          [
            { num: `${photos.length}+`, label: "Робіт в архіві" },
            { num: `${members.length}`, label: "Учасники" },
            { num: "5+", label: "Років разом" },
            { num: "12", label: "Виставок" },
          ].map(({ num, label }) => (
            <div class="border border-film-700 p-6">
              <span class=" text-4xl font-semibold text-film-100">
                {num}
              </span>
              <p class=" text-xs text-film-400 uppercase tracking-widest mt-1">
                {label}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
