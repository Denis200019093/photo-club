---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Контакти" description="Зв'яжіться з вінницьким фотоклубом">

  <section class="max-w-7xl mx-auto px-6 pt-16 pb-12">
    <p class=" text-xs text-film-400 uppercase tracking-[0.2em] mb-3">Зв'яжіться з нами</p>
    <h1 class=" text-5xl sm:text-6xl font-semibold text-film-950">
      Контакти
    </h1>
  </section>

  <div class="max-w-7xl mx-auto px-6">
    <div class="border-t border-film-200" />
  </div>

  <section class="max-w-7xl mx-auto px-6 py-14 grid grid-cols-1 lg:grid-cols-2 gap-16">

    <!-- LEFT: Contact details -->
    <div class="flex flex-col gap-10">
      <div>
        <p class=" text-xs text-film-400 uppercase tracking-[0.2em] mb-6">Де нас знайти</p>
        <div class="space-y-6">

          <!-- Address -->
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 border border-film-200 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-film-500">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="font-body text-film-900 text-sm font-medium">Вінниця, вул. Соборна, 24</p>
              <p class="font-body text-film-500 text-sm mt-0.5">Культурний центр «Промінь», 2-й поверх</p>
            </div>
          </div>

          <!-- Email -->
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 border border-film-200 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-film-500">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <a
                href="mailto:hello@fclub.vn.ua"
                class="font-body text-film-900 text-sm font-medium hover:text-film-500 transition-colors"
              >
                hello@fclub.vn.ua
              </a>
              <p class="font-body text-film-500 text-sm mt-0.5">Відповідаємо впродовж доби</p>
            </div>
          </div>

          <!-- Instagram -->
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 border border-film-200 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-film-500">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
              </svg>
            </div>
            <div>
              <a
                href="https://instagram.com/fclub.vn"
                target="_blank"
                rel="noopener"
                class="font-body text-film-900 text-sm font-medium hover:text-film-500 transition-colors"
              >
                @fclub.vn
              </a>
              <p class="font-body text-film-500 text-sm mt-0.5">Instagram</p>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- RIGHT: Meetings schedule -->
    <div>
      <p class=" text-xs text-film-400 uppercase tracking-[0.2em] mb-6">Зустрічі</p>
      <div class="space-y-px">
        {[
          {
            day: 'Перша субота місяця',
            time: '18:00',
            title: 'Обговорення робіт',
            desc: 'Кожен учасник представляє нові роботи, отримує зворотній зв\'язок від клубу.',
          },
          {
            day: 'Третя субота місяця',
            time: '10:00',
            title: 'Спільна фотопрогулянка',
            desc: 'Виходимо на зйомку разом — по місту або за його межами.',
          },
          {
            day: 'Раз на квартал',
            time: 'за анонсом',
            title: 'Відкрита виставка',
            desc: 'Публічна презентація кращих робіт сезону.',
          },
        ].map(({ day, time, title, desc }) => (
          <div class="border border-film-200 p-6 hover:border-film-400 transition-colors duration-200">
            <div class="flex items-start justify-between gap-4 mb-2">
              <div>
                <p class="font-body text-film-900 text-sm font-medium">{title}</p>
                <p class=" text-xs text-film-400 mt-0.5">{day}</p>
              </div>
              <span class=" text-sm text-film-600 shrink-0 pt-0.5">{time}</span>
            </div>
            <p class="font-body text-film-500 text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>

      <p class="font-body text-film-400 text-xs mt-5 leading-relaxed">
        Анонси всіх зустрічей публікуємо в Instagram. Нові учасники завжди вітаються — просто напишіть нам на email.
      </p>
    </div>

  </section>

</Layout>
